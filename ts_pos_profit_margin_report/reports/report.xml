<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="action_pos_gp_report_xlsx" model="ir.actions.report">
            <field name="name">Print POS Gross Profit Report</field>
            <field name="model">ts.pos.report</field>
            <field name="report_type">xlsx</field>
            <field name="report_name">ts_pos_profit_margin_report.pos_report</field>
            <field name="report_file">ts_pos_profit_margin_report.pos_report</field>
            <field name="binding_model_id" ref="ts_pos_profit_margin_report.model_ts_pos_report"/>
            <field name="binding_type">report</field>
        </record>

        <!-- Report Wizard & Menu starts here -->
        <record id="pos_gp_report_wizard_form_view" model="ir.ui.view">
            <field name="name">pos.report.wizard.form.view</field>
            <field name="model">ts.pos.report</field>
            <field name="arch" type="xml">
                <form>
                    <group>
                        <group>
                            <field name="date_from"/>
                            <field name="pos_order_id" options="{'no_create': True, 'no_create_edit':True}"/>
                            <field name="location_id" options="{'no_create': True, 'no_create_edit':True}"/>
                            <field name="partner_ids" widget="many2many_tags"/>
                        </group>
                        <group>
                            <field name="date_to"/>
                            <field name="company_id" options="{'no_create': True, 'no_create_edit':True}"/>
                            <field name="product_ids" widget="many2many_tags"/>
                            <field name="product_type"/>
                        </group>
                    </group>
                    <footer>
                        <button name="generate_pos_report" string="Generate Report" type="object" default_focus="1"
                                class="oe_highlight"/>
                        <button string="Cancel" class="btn btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_pos_gp_report_wizard" model="ir.actions.act_window">
            <field name="name">Pos Report</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">ts.pos.report</field>
            <field name="view_id" ref="pos_gp_report_wizard_form_view"/>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

    </data>
</odoo>