<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="view_stock_move_line_form_inherit">
            <field name="name">stock.move.line.form</field>
            <field name="model">stock.move.line</field>
            <field name="inherit_id" ref="stock.view_move_line_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='state']" position="before">
                    <button name="set_recipe_product" string="Set Recipe Product" type="object" class="oe_highlight"
                            groups="base.group_system"/>
                </xpath>
                <xpath expr="//field[@name='product_id']" position="after">
                    <field name="parent_product_id"/>
                </xpath>
                <xpath expr="//sheet" position="inside">
                    <notebook>
                        <page string="Valuation">
                            <group>
                                <!-- <field name="qty_done"/> -->
                                <field name="quantity"/>
                                <field name="uom_id" groups="uom.group_uom"/>
                                <field name="unit_cost" force_save="1"/>
                                <field name="value" readonly="1"/>
                            </group>
                        </page>
                        <page string="Other Info">
                            <group>
                                <group>
                                    <field name="sale_order_id" force_save="1"
                                           invisible="'sale_order_id', '=', False"/>
                                    <field name="pos_order_id" force_save="1"
                                           invisible="'pos_order_id', '=', False"/>
                                    <field name="pos_session_id" force_save="1"
                                           invisible="'pos_session_id', '=', False"/>
                                </group>

                            </group>
                        </page>
                    </notebook>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
