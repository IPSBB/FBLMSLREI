<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Form view of Period Lock -->
    <record id="view_form_period_lock" model="ir.ui.view">
        <field name="name">account.period.lock.form</field>
        <field name="model">account.period.lock</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <!-- Button to Lock the Period -->
                    <button name="action_lock" type="object" string="Lock"
                        class="btn-primary" invisible="state == 'locked' "/>
                    <button name="action_unlock" type="object" string="Unlock"
                        class="btn-primary" invisible="state == 'draft' or state == 'unlocked' "/>
                    <button name="action_draft" type="object" string="Reset to Draft"
                        class="btn-secondary" invisible="state == 'draft'"/>

                    <!-- Status Bar -->
                    <field name="state" widget="statusbar" statusbar_visible="draft,locked,unlocked" />
                </header>
                <sheet>
                    <h1><field name="name"></field></h1>
                    <group>
                        <group>
                            <field name="journal_ids" widget="many2many_tags" />
                            <field name="company_ids" widget="many2many_tags" />
                        </group>
                        <group>
                            <field name="from_date" />
                            <field name="to_date" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
        <!-- <field name="groups_id" eval="[(4, ref('cr_period_lock.group_period_lock_special_permission'))]"/> -->
    </record>

    <!-- Tree view of Period Lock -->
    <record id="view_tree_period_lock" model="ir.ui.view">
        <field name="name">account.period.lock.tree</field>
        <field name="model">account.period.lock</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" />
                <field name="from_date" />
                <field name="to_date" />
                <field name="journal_ids" widget="many2many_tags"/>
                <field name="company_ids" widget="many2many_tags"/>
            </tree>
        </field>
        <!-- <field name="groups_id" eval="[(4, ref('cr_period_lock.group_period_lock_special_permission'))]"/> -->
    </record>

    <!-- Action for period lock -->
    <record id="action_period_lock" model="ir.actions.act_window">
        <field name="name">Period Lock</field>
        <field name="res_model">account.period.lock</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Add Period Lock to the menu -->
    <menuitem id="menu_period_lock_main"
        name="Period Lock"
        parent="account.menu_finance"
        action="action_period_lock"
        sequence="20" />

</odoo>